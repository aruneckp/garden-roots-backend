# ============================================================
# Garden Roots Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Oracle Database ──────────────────────────────────────────
DB_USER=system
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=XEPDB1

# ── Oracle Wallet (Oracle Autonomous Database / cloud only) ──
# Leave all blank for local Oracle XE.
#
# 1. Unzip your wallet: unzip Wallet_MyDB.zip -d wallet/
# 2. Base64-encode ewallet.p12:
#      macOS/Linux: base64 -i wallet/ewallet.p12 | tr -d '\n'
#      PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes('wallet\ewallet.p12'))
ORACLE_EWALLET_P12_B64=
# Wallet password (set during wallet download from OCI console)
ORACLE_WALLET_PASSWORD=
# Paste the full contents of wallet/tnsnames.ora (single-line, spaces OK)
ORACLE_TNSNAMES=
# Paste the full contents of wallet/sqlnet.ora
ORACLE_SQLNET=

# ── FastAPI ──────────────────────────────────────────────────
API_TITLE=Garden Roots API
API_VERSION=1.0.0
DEBUG=False

# ── CORS ─────────────────────────────────────────────────────
# Add your production domain here when deploying:
# e.g. ["https://gardenroots.sg","https://www.gardenroots.sg"]
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# ── Stripe ───────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Get the webhook secret by running:
#   stripe listen --forward-to localhost:8000/api/v1/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Public URL of this backend (used as Stripe return_url)
APP_URL=http://localhost:8000

# ── Business Rules ───────────────────────────────────────────
# Orders above this subtotal get free delivery (SGD)
DELIVERY_FREE_THRESHOLD=120.0
# Flat delivery fee when below threshold (SGD)
DELIVERY_COST=12.0
